# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored; this `.env.example` is the tracked template.
#
# `.env` is read automatically by `wrangler dev` / `npm run dev` for local
# development AND uploaded to Cloudflare as production secrets when you run:
#   npm run deploy:secrets

# Address the agent replies from. Must be on a domain you've onboarded
# to Cloudflare Email Service.
EMAIL_FROM=research@example.com
